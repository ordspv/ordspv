{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node",
      "chrome"
    ],
    "noEmit": true,
    "paths": {
      "@ordspv/core": [
        "./packages/core/src/index.ts"
      ],
      "@ordspv/fetch": [
        "./packages/fetch/src/index.ts"
      ]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "scripts/**/*.ts",
    "examples/src/**/*.ts",
    "extension/src/**/*.ts",
    "extension/test/**/*.ts"
  ]
}
